@model PuntoVentaWeb.Entities.ProductoEnt

@{
    ViewData["Title"] = "Actualizar Producto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="modal-dialog modal-lg" role="document">
    <div class="modal-content">
        <div class="modal-header">
            <h5 class="modal-title" id="modalActualizarProductoLabel">Actualizar Producto</h5>
        </div>
        <div class="modal-body">
            <form id="formProducto" asp-action="ActualizarProducto">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="IdProducto" class="control-label"></label>
                    <input asp-for="IdProducto" class="form-control" readonly />
                    <span asp-validation-for="IdProducto" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Nombre" class="control-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Precio" class="control-label"></label>
                    <input asp-for="Precio" class="form-control"
                           inputmode="numeric" pattern="[0-9]*" step="0.01" />
                    <span asp-validation-for="Precio" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Stock" class="control-label"></label>
                    <input asp-for="Stock" class="form-control"
                           inputmode="numeric" pattern="[0-9]*" min="0" max="200" step="1" />
                    <span asp-validation-for="Stock" class="text-danger"></span>
                </div>


                <!-- Dropdown de Categorías -->
                <div class="form-group">
                    <label asp-for="IdCategoria" class="control-label"></label>
                    <select asp-for="IdCategoria" class="form-control" id="IdCategoria">
                        <option value="">Seleccione una categoría</option>
                    </select>
                    <span asp-validation-for="IdCategoria" class="text-danger"></span>
                </div>

                <div class="form-group text-right">
                    <a asp-action="ConsultarProductos" class="btn btn-secondary">Cancelar</a>
                    <input type="submit" value="Actualizar" class="btn btn-primary" id="btnActualizar" />
                </div>
            </form>
        </div>
    </div>
</div>

<!-- SweetAlert2 CSS y JS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    let categoriasValidas = [];

    // Llamada a la API para cargar las categorías al iniciar la página
    window.onload = async function () {
        try {
            const response = await fetch('https://localhost:7007/api/Categoria/ConsultarCategorias');
            const data = await response.json();

            console.log('Respuesta API:', data);

            if (data.Codigo === "1" && data.Datos) {
                categoriasValidas = data.Datos.map(c => c.Id.toString());
                console.log('Categorías cargadas:', categoriasValidas);

                const categoriaSelect = document.getElementById('IdCategoria');
                data.Datos.forEach(categoria => {
                    const option = document.createElement('option');
                    option.value = categoria.Id;
                    option.textContent = categoria.Nombre;
                    categoriaSelect.appendChild(option);
                });
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Sin categorías',
                    text: 'No hay categorías registradas o hubo un problema.',
                });
            }
        } catch (error) {
            console.error('Error al consultar categorías:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'No se pudieron cargar las categorías.',
            });
        }
    };

    // Validación para solo números en los campos numéricos
    ['Precio', 'Stock'].forEach(field => {
        document.querySelector(`[name="${field}"]`).addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9.]/g, ''); // Permitir solo números y puntos decimales
        });
    });

    document.getElementById('btnActualizar').addEventListener('click', function (e) {
        e.preventDefault(); // Evita el envío del formulario si hay error

        const idCategoria = document.getElementById('IdCategoria').value.trim();
        console.log('ID de Categoría ingresado:', idCategoria);
        console.log('Categorías válidas:', categoriasValidas);

        if (!categoriasValidas.includes(idCategoria)) {
            Swal.fire({
                icon: 'error',
                title: 'Categoría no válida',
                text: 'La categoría no existe. No se puede actualizar el producto.',
            });
        } else {
            Swal.fire({
                icon: 'success',
                title: 'Producto actualizado',
                text: 'El producto se ha actualizado exitosamente.',
            }).then(() => {
                document.getElementById('formProducto').submit(); // Enviar el formulario
            });
        }
    });
</script>
